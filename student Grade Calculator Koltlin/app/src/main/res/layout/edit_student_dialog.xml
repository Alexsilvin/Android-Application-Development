<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Student Name (Read-only) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student Name"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/android:textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/editStudentName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textColor="?attr/android:textColor"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Student Matricule (Read-only) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student Matricule"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/android:textColorSecondary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/editStudentMatricule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textColor="?attr/android:textColor"
            android:padding="8dp" />
    </LinearLayout>

    <!-- CA Mark -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CA Mark (0-30)"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/android:textColorSecondary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editCaMark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:inputType="numberDecimal"
            android:hint="Enter CA Mark"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Exam Mark -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exam Mark (0-70)"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/android:textColorSecondary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editExamMark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:inputType="numberDecimal"
            android:hint="Enter Exam Mark"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Buttons Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/buttonDeleteStudent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DELETE"
            android:textColor="@color/delete_color"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/buttonCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CANCEL" />

        <Button
            android:id="@+id/buttonSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVE"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
